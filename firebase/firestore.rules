rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- /users/{userId} ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // --- /items/{itemId} ---
    match /items/{itemId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    // --- /reservations/{reservationId} ---
    match /reservations/{reservationId} {
      // Read open to any auth user so date-blocking queries work
      // (anyone checking item availability needs to see confirmed reservations)
      allow read: if isAuthenticated();
      // Create: only the renter can create their own reservation
      allow create: if isAuthenticated() &&
        request.auth.uid == request.resource.data.renterId;
      // Update: only the involved parties can change it
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.ownerId ||
        request.auth.uid == resource.data.renterId
      );
      allow delete: if false;
    }

    // --- /ratings/{ratingId} ---
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.fromUserId;
      allow delete: if false;
    }

    // --- /chats/{chatId}/messages/{messageId} ---
    match /chats/{chatId} {
      // Permite get por ID si el chatId contiene el uid del usuario.
      // Esto cubre el caso de comprobar existencia antes de crear el chat.
      allow get: if isAuthenticated() &&
        request.auth.uid in chatId.split('_');
      // Listar solo los chats donde el usuario es participante.
      allow list: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.auth.uid == request.resource.data.senderId;
        allow update, delete: if false;
      }
    }
  }
}
